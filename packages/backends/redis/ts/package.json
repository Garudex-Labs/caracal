{
  "name": "@caracalai/revocation-redis",
  "version": "0.2.0-rc.4",
  "description": "Caracal Redis-backed revocation store.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/backends/redis/ts"
  },
  "keywords": [
    "caracal",
    "redis",
    "revocation",
    "backend"
  ],
  "type": "module",
