      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../../../.. tests/typescript/unit/backends/redis",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@caracalai/core": "0.2.0-rc.4",
    "@caracalai/revocation": "0.2.0-rc.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
