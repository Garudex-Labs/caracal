{
  "name": "@caracalai/identity",
  "version": "0.1.0",
  "description": "Caracal identity primitives: JWT verification, JWKS, scope, claims.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/identity/ts"
  },
  "keywords": ["caracal", "identity", "jwt", "jwks"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../../.. tests/typescript/unit/identity",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@caracalai/core": "workspace:*",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
