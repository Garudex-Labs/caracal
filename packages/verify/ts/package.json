{
  "name": "@caracalai/verify",
  "version": "0.1.6-rc.3",
  "description": "Caracal framework-neutral mandate verification engine.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/verify/ts"
  },
  "keywords": [
    "caracal",
    "verification",
    "mandate",
    "jwt"
  ],
  "type": "module",
