    "test": "vitest run --root ../../.. tests/typescript/unit/verify",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@caracalai/identity": "0.1.6-rc.3",
    "@caracalai/revocation": "0.1.6-rc.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
