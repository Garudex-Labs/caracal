 *
 * Compact community strip with the featured video, featured blog post, and blog and vlog links.
 */

import { getCollection } from "astro:content";
import community from "../data/community.json";

const featured = community.vlogs.find((v) => v.featured);

const posts = await getCollection("docs", (entry) => entry.id.startsWith("blog/") && Boolean(entry.data.post));
const featuredPost = posts
  .sort((a, b) => new Date(b.data.post!.date).valueOf() - new Date(a.data.post!.date).valueOf())
  .find((entry) => entry.data.post!.featured) ?? posts[0];
const postMeta = featuredPost?.data.post;
const postTint = postMeta
  ? (community.blogCategories as { name: string; tint: string }[]).find((c) => c.name === postMeta.category)?.tint ?? "#60a5fa"
  : "#60a5fa";
const postDate = postMeta
  ? new Date(postMeta.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
  : "";
---

<section class="docs-strip" aria-labelledby="docs-strip-heading">
  <div class="docs-strip__inner">

    <div class="docs-strip__intro">
      <p class="docs-section__eyebrow">Community</p>
      <h2 id="docs-strip-heading" class="docs-strip__heading">We build this in the open</h2>
      <p class="docs-strip__lede">Talks, posts, and a weekly call where the roadmap actually gets decided.</p>
      <div class="docs-strip__actions">
        <a class="landing-button landing-button--secondary" href="/blogs/">Read the blog</a>
        <a class="landing-button landing-button--secondary" href="/vlogs/">Watch the vlogs</a>
      </div>
    </div>

    {featured && (
      <a class="docs-strip__video" href={featured.href} target="_blank" rel="noopener noreferrer">
        <span class="docs-strip__thumb">
          <img src={`https://img.youtube.com/vi/${featured.youtubeId}/hqdefault.jpg`} alt="" loading="lazy" width="480" height="360" />
          <span class="vlog-play" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3" /></svg>
          </span>
        </span>
        <span class="docs-strip__video-meta">
          <span class="docs-strip__video-kicker">{featured.category}</span>
          <span class="docs-strip__video-title">{featured.title}</span>
        </span>
      </a>
    )}

    {featuredPost && postMeta && (
      <a class="docs-strip__post" href={`/${featuredPost.id}/`} style={`--tint: ${postTint}`}>
        <span class="docs-strip__post-kicker">
          <span class="chip">{postMeta.category}</span>
          <span class="docs-strip__post-label">From the blog</span>
        </span>
        <span class="docs-strip__post-title">{featuredPost.data.title}</span>
        <span class="docs-strip__post-desc">{featuredPost.data.description}</span>
        <span class="docs-strip__post-meta">
          <span>{postMeta.author}</span>
          <span>{postDate}</span>
          {postMeta.readingTime && <span>{postMeta.readingTime}</span>}
        </span>
      </a>
    )}

  </div>
</section>
