 *
 * Single HTTP endpoint documentation block with deep-link ID.
 */

type Method = 'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH'
type ServiceName = 'sts' | 'gateway' | 'coordinator' | 'audit'

interface ErrorDef {
  code: string
  description: string
  remediation?: string
}

interface Props {
  method: Method
  path: string
  service: ServiceName
  description: string
  auth: string
  requestSchema?: string
  responseSchema?: string
  errors?: ErrorDef[]
}

const { method, path, service, description, auth, requestSchema, responseSchema, errors } = Astro.props

const id = `${method.toLowerCase()}-${path.replace(/\//g, '-').replace(/^-|-$/g, '')}`
---

<div class="api-endpoint" id={id}>
  <div class="api-endpoint-header">
    <span class={`api-method api-method-${method.toLowerCase()}`}>{method}</span>
    <code class="api-path">{path}</code>
    <span class="api-service">{service}</span>
  </div>
  <p>{description}</p>
  <p><strong>Auth:</strong> {auth}</p>
  {requestSchema && (
    <details open>
      <summary>Request</summary>
      <pre><code class="language-json">{requestSchema}</code></pre>
    </details>
  )}
  {responseSchema && (
    <details open>
      <summary>Response</summary>
      <pre><code class="language-json">{responseSchema}</code></pre>
    </details>
  )}
  {errors && errors.length > 0 && (
    <dl class="api-errors">
      <dt>Errors</dt>
      {errors.map((e) => (
        <dd>
          <code>{e.code}</code> — {e.description}
          {e.remediation && <span> ({e.remediation})</span>}
        </dd>
      ))}
    </dl>
  )}
</div>
