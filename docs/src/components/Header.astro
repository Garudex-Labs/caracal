 *
 * Site header with logo and theme toggle.
 */
import Default from '@astrojs/starlight/components/Header.astro'
import ThemeSelect from './ThemeSelect.astro'

const route = (Astro.locals as any)?.starlightRoute
const isLanding = route?.entry?.data?.template === 'splash'
---

{
  isLanding ? (
    <header class="site-nav">
      <a class="site-nav__brand" href="/" aria-label="Caracal home">
        <img class="site-nav__logo" src="/img/caracal.png" alt="" width="28" height="28" />
        <span>Caracal</span>
      </a>
      <nav class="site-nav__menu" aria-label="Main navigation">
        <a class="site-nav__link" href="/blogs/">Blogs</a>
        <a class="site-nav__link" href="/vlogs/">Vlogs</a>
      </nav>
      <div class="site-nav__end">
        <details class="edition-menu">
          <summary class="edition-menu__button">
            <span>Open Source</span>
            <svg aria-hidden="true" width="13" height="13" viewBox="0 0 24 24" fill="none">
              <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
            </svg>
          </summary>
          <div class="edition-menu__panel">
            <a class="edition-menu__item" href="/">
              <span>Open Source</span>
              <span class="edition-menu__current">Current</span>
            </a>
            <span class="edition-menu__item edition-menu__item--disabled" aria-disabled="true">
              <span>Enterprise</span>
              <span class="edition-menu__soon">Coming soon</span>
            </span>
          </div>
        </details>
        <ThemeSelect />
      </div>
    </header>
  ) : (
    <Default />
  )
}

<script is:inline>
  (() => {
    const hero = document.querySelector<HTMLElement>('.landing-hero');
    const nav = document.querySelector<HTMLElement>('.site-nav');
    if (!hero || !nav) return;
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }
    const updateNav = () => {
      const threshold = Math.max(0, hero.offsetHeight - nav.offsetHeight - 16);
      nav.dataset.overHero = String(window.scrollY < threshold);
    };
    updateNav();
    window.addEventListener('scroll', updateNav, { passive: true });
    window.addEventListener('resize', updateNav);
    const navEntry = performance.getEntriesByType('navigation')[0];
    const isReload = navEntry && navEntry.type === 'reload';
    if (isReload) {
      if (window.location.hash) {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }
      window.scrollTo(0, 0);
    }
  })();
</script>

<script is:inline>
  (() => {
    const init = () => {
      let btn = document.querySelector('.back-to-top');
      if (!btn) {
        btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'back-to-top';
        btn.setAttribute('aria-label', 'Back to top');
        btn.dataset.visible = 'false';
        btn.innerHTML =
          '<svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5"/><path d="M5 12l7-7 7 7"/></svg>';
        document.body.appendChild(btn);
      }
      if (btn.dataset.bound === 'true') return;
      btn.dataset.bound = 'true';
      const update = () => {
        btn.dataset.visible = String(window.scrollY > 200);
      };
      update();
      window.addEventListener('scroll', update, { passive: true });
      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('astro:page-load', init);
  })();
</script>

<style is:global>
  body:has(.landing-hero) > .page > header.header {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 100 !important;
    background: transparent !important;
    border-bottom: 0 !important;
    padding: 0 !important;
    height: 0 !important;
  }

  body:has(.landing-hero) .site-nav[data-over-hero='true'] .theme-toggle {
    border-color: #2a2f45;
    background: #0d1020;
    color: rgba(255, 255, 255, 0.92);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.24);
  }

  body:has(.landing-hero) .site-nav[data-over-hero='true'] .theme-toggle:hover {
    border-color: #eca8d6;
    color: #fff;
  }

  body:has(.landing-hero) .site-nav[data-over-hero='true'] .edition-menu__button {
    border-color: #2a2f45;
    background: #0d1020;
    color: rgba(255, 255, 255, 0.88);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.24);
  }

  body:has(.landing-hero) .site-nav[data-over-hero='true'] .edition-menu__button:hover {
    border-color: #eca8d6;
    color: #fff;
  }
</style>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem clamp(1rem, 4vw, 2rem);
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
  }

  .site-nav__menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-nav__link {
    font-family: 'Space Grotesk', var(--sl-font);
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.76);
    text-decoration: none;
    transition: color 0.16s ease;
  }

  .site-nav__link:hover {
    color: #fff;
  }

  .site-nav[data-over-hero='false'] .site-nav__link {
    color: var(--caracal-text-muted, var(--sl-color-text));
  }

  .site-nav[data-over-hero='false'] .site-nav__link:hover {
    color: var(--sl-color-text);
  }

  .site-nav[data-over-hero='false'] {
    background: color-mix(in srgb, var(--sl-color-bg) 94%, transparent);
    border-bottom-color: var(--sl-color-hairline);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-nav .site-nav__brand,
  .site-nav[data-over-hero='true'] .site-nav__brand {
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.42);
  }

  .site-nav .site-nav__brand:hover,
  .site-nav[data-over-hero='true'] .site-nav__brand:hover {
    color: #fff;
  }

  .site-nav .site-nav__logo,
  .site-nav[data-over-hero='true'] .site-nav__logo {
    filter: invert(1) grayscale(1) brightness(1.8);
  }

  .site-nav[data-over-hero='false'] .site-nav__brand {
    color: var(--caracal-text-muted, var(--sl-color-text));
    text-shadow: none;
  }

  .site-nav[data-over-hero='false'] .site-nav__brand:hover {
    color: var(--sl-color-text);
  }

  :root[data-theme='light'] .site-nav[data-over-hero='false'] .site-nav__logo {
    filter: none;
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Space Grotesk', var(--sl-font);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--sl-color-text);
    text-decoration: none;
    justify-self: start;
  }

  .site-nav__brand img {
    display: block;
    border-radius: 6px;
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  :root:not([data-theme='light']) .site-nav__logo {
    filter: invert(1);
  }

  .site-nav__end {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .edition-menu {
    position: relative;
  }

  .edition-menu__button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2rem;
    padding: 0 0.72rem;
    border: 1px solid var(--caracal-border-strong);
    border-radius: 6px;
    background: var(--caracal-panel-strong);
    color: var(--sl-color-text);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1;
    list-style: none;
    cursor: pointer;
    box-shadow: 0 2px 8px color-mix(in srgb, black 16%, transparent);
    transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
  }

  .edition-menu__button::-webkit-details-marker {
    display: none;
  }

  .edition-menu__button:hover {
    transform: translateY(-1px);
    border-color: var(--caracal-link);
    box-shadow: 0 4px 12px color-mix(in srgb, black 18%, transparent);
  }

  .edition-menu__button svg {
    opacity: 0.68;
    transition: transform 0.16s ease;
  }

  .edition-menu[open] .edition-menu__button svg {
    transform: rotate(180deg);
  }

  .edition-menu__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 13rem;
    padding: 0.35rem;
    border: 1px solid var(--caracal-border-strong);
    border-radius: 8px;
    background: var(--caracal-panel-strong);
    box-shadow: 0 14px 32px color-mix(in srgb, black 28%, transparent);
  }

  .edition-menu__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    padding: 0.62rem 0.7rem;
    border-radius: 5px;
    color: var(--sl-color-text);
    font-size: 0.84rem;
    font-weight: 600;
    text-decoration: none;
  }

  .edition-menu__item:hover {
    background: color-mix(in srgb, var(--caracal-link) 12%, transparent);
  }

  .edition-menu__item--disabled {
    color: var(--caracal-text-subtle);
    cursor: not-allowed;
  }

  .edition-menu__item--disabled:hover {
    background: transparent;
  }

  .edition-menu__current,
  .edition-menu__soon {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .edition-menu__current {
    color: var(--caracal-link);
  }

  .edition-menu__soon {
    color: color-mix(in srgb, var(--caracal-text-subtle) 80%, transparent);
  }
</style>

<style is:global>
  .back-to-top {
    position: fixed;
    right: clamp(0.875rem, 2.4vw, 1.5rem);
    bottom: clamp(0.875rem, 2.4vw, 1.5rem);
    z-index: 90;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    padding: 0;
    border: 1px solid color-mix(in srgb, var(--sl-color-text) 18%, transparent);
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--sl-color-bg) 88%, transparent);
    color: var(--sl-color-text);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: opacity 0.16s ease, transform 0.16s ease, background 0.14s ease, border-color 0.14s ease, color 0.14s ease;
    box-shadow: 0 8px 18px color-mix(in srgb, black 16%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .back-to-top[data-visible='true'] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .back-to-top:hover {
    background: var(--caracal-panel-strong);
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-text-accent);
  }
</style>
