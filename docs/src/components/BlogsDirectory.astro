---
/*
 * Copyright (C) 2026 Garudex Labs.  All Rights Reserved.
 * Caracal, a product of Garudex Labs
 *
 * Blog index built from the content collection with tinted cover cards, author bylines, search, category filters, and pagination.
 */

import { getCollection } from "astro:content";
import community from "../data/community.json";

interface PostMeta {
  category: string;
  author: string;
  role?: string;
  date: Date;
  readingTime?: string;
  tags?: string[];
  featured?: boolean;
}

const categories = community.blogCategories as { name: string; tint: string }[];
const tintFor = (name: string) => categories.find((c) => c.name === name)?.tint ?? "#60a5fa";
const initials = (name: string) =>
  name
    .split(/\s+/)
    .map((word) => word[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();

const coverIcons: Record<string, string> = {
  Engineering: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  Security: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  Tutorials: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  Community: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  Releases: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
};

const entries = await getCollection("docs", (entry) => entry.id.startsWith("blog/") && Boolean(entry.data.post));
const posts = entries
  .map((entry) => ({
    href: `/${entry.id}/`,
    title: entry.data.title,
    description: entry.data.description ?? "",
    ...(entry.data.post as PostMeta),
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const activeCategories = categories.filter((c) => posts.some((p) => p.category === c.name));
const heroHref = (posts.find((p) => p.featured) ?? posts[0])?.href;
const discord = community.discordInvite;

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<section class="media-page" aria-labelledby="blogs-heading">
  <div class="media-page__inner" data-media-top>

    <header class="media-head">
      <div class="media-head__row">
        <div>
          <h1 id="blogs-heading" class="media-head__title">Blog</h1>
          <p class="media-head__lede">
            Notes from the Caracal team and community on securing agents in production: policy design,
            delegation patterns, identity, and audit.
          </p>
        </div>
        <button class="media-head__submit" type="button" data-submit-open>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 20h9" /><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
          </svg>
          Write for Caracal
        </button>
      </div>
    </header>

    {posts.length > 0 ? (
      <>
        <div class="media-toolbar">
          <div class="media-filterset" role="group" aria-label="Filter posts by category">
            <button class="media-tab isActive" type="button" data-media-filter="all">All</button>
            {activeCategories.map((category) => (
              <button class="media-tab" type="button" data-media-filter={category.name} style={`--tint: ${category.tint}`}>
                {category.name}
              </button>
            ))}
          </div>
          <label class="media-search">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="search" placeholder="Search posts" aria-label="Search blog posts" data-media-search />
          </label>
        </div>

        <div class="post-grid" data-media-list>
          {posts.map((post) => (
            <a
              class={`bcard${post.href === heroHref ? " bcard--hero" : ""}`}
              href={post.href}
              style={`--tint: ${tintFor(post.category)}`}
              data-media-item
              data-media-category={post.category}
              data-media-text={`${post.title} ${post.description} ${post.category} ${post.author} ${(post.tags ?? []).join(" ")}`.toLowerCase()}
            >
              <span class="bcard__cover" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={coverIcons[post.category] ?? coverIcons.Engineering} />
                {post.href === heroHref && <span class="bcard__flag">Featured</span>}
              </span>
              <span class="bcard__body">
                <span class="chip">{post.category}</span>
                <span class="bcard__title">{post.title}</span>
                <span class="bcard__desc">{post.description}</span>
                <span class="bcard__foot">
                  <span class="avatar" aria-hidden="true">{initials(post.author)}</span>
                  <span class="bcard__byline">
                    <span class="bcard__author">{post.author}</span>
                    {post.role && <span class="bcard__role">{post.role}</span>}
                  </span>
                  <span class="bcard__when">
                    <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
                    {post.readingTime && <span>{post.readingTime}</span>}
                  </span>
                </span>
              </span>
            </a>
          ))}
        </div>

        <p class="media-empty" data-media-noresults hidden>Nothing matches that search.</p>

        <div class="media-foot">
          <p class="media-count" data-media-count aria-live="polite"></p>
          <nav class="pager" data-media-pager aria-label="Pagination" hidden></nav>
        </div>
      </>
    ) : (
      <div class="media-launch">
        <p class="media-launch__title">First posts are in the works</p>
        <p class="media-launch__body">
          The blog opens with deep dives on pre-execution authorization, mandate design, and multi-agent
          delegation. Want to write one of the first posts? Hit "Write for Caracal" above.
        </p>
      </div>
    )}

  </div>
</section>

<dialog class="media-dialog" data-submit-dialog aria-labelledby="blogs-submit-title">
  <div class="media-dialog__head">
    <h2 id="blogs-submit-title" class="media-dialog__title">Write for Caracal</h2>
    <button class="media-dialog__close" type="button" data-submit-close aria-label="Close">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>
  <ol class="media-dialog__steps" role="list">
    <li class="submit-step">
      <span class="submit-step__num" aria-hidden="true">1</span>
      <div>
        <h3 class="submit-step__title">Join the Discord server</h3>
        <p class="submit-step__body">Submissions go through the Caracal community Discord, where maintainers review content.</p>
      </div>
    </li>
    <li class="submit-step">
      <span class="submit-step__num" aria-hidden="true">2</span>
      <div>
        <h3 class="submit-step__title">Pitch your post</h3>
        <p class="submit-step__body">Share a short pitch or a draft link: topic, audience, and what readers take away.</p>
      </div>
    </li>
    <li class="submit-step">
      <span class="submit-step__num" aria-hidden="true">3</span>
      <div>
        <h3 class="submit-step__title">Get reviewed and featured</h3>
        <p class="submit-step__body">Accepted posts are listed here, and standout posts are featured on the docs home page.</p>
      </div>
    </li>
  </ol>
  <div class="media-dialog__criteria">
    <h3 class="media-dialog__criteria-title">What we look for</h3>
    <ul class="media-dialog__checklist">
      <li>Real implementations and honest trade-offs</li>
      <li>Agent security, authority, identity, or audit themes</li>
      <li>Reproducible examples over abstract claims</li>
      <li>Your voice. We edit lightly and credit fully</li>
    </ul>
  </div>
  <a class="landing-button landing-button--primary" href={discord} target="_blank" rel="noopener noreferrer">
    Open Discord
  </a>
</dialog>

<script>
  const dialog = document.querySelector<HTMLDialogElement>("[data-submit-dialog]");
  document.querySelector<HTMLButtonElement>("[data-submit-open]")?.addEventListener("click", () => dialog?.showModal());
  document.querySelector<HTMLButtonElement>("[data-submit-close]")?.addEventListener("click", () => dialog?.close());
  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });

  const search = document.querySelector<HTMLInputElement>("[data-media-search]");
  const filters = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-media-filter]"));
  const items = Array.from(document.querySelectorAll<HTMLElement>("[data-media-item]"));
  const noResults = document.querySelector<HTMLElement>("[data-media-noresults]");
  const count = document.querySelector<HTMLElement>("[data-media-count]");
  const pager = document.querySelector<HTMLElement>("[data-media-pager]");
  const top = document.querySelector<HTMLElement>("[data-media-top]");

  const pageSize = 6;
  let category = "all";
  let query = "";
  let page = 1;

  const matches = (item: HTMLElement) =>
    (category === "all" || item.dataset.mediaCategory === category) &&
    (!query || (item.dataset.mediaText ?? "").includes(query));

  const pageNumbers = (pages: number, current: number): (number | null)[] => {
    if (pages <= 7) return Array.from({ length: pages }, (_, i) => i + 1);
    const wanted = [...new Set([1, current - 1, current, current + 1, pages])]
      .filter((p) => p >= 1 && p <= pages)
      .sort((a, b) => a - b);
    const out: (number | null)[] = [];
    let prev = 0;
    for (const p of wanted) {
      if (p - prev > 1) out.push(null);
      out.push(p);
      prev = p;
    }
    return out;
  };

  const renderPager = (pages: number) => {
    if (!pager) return;
    pager.hidden = pages <= 1;
    pager.replaceChildren();
    if (pages <= 1) return;
    const nav = (label: string, target: number, disabled: boolean) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "pager__btn";
      button.textContent = label;
      button.disabled = disabled;
      button.addEventListener("click", () => {
        page = target;
        apply();
        top?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
      return button;
    };
    pager.append(nav("\u2190", page - 1, page === 1));
    for (const num of pageNumbers(pages, page)) {
      if (num === null) {
        const gap = document.createElement("span");
        gap.className = "pager__gap";
        gap.textContent = "\u2026";
        pager.append(gap);
        continue;
      }
      const button = nav(String(num), num, false);
      button.classList.toggle("isActive", num === page);
      button.setAttribute("aria-current", num === page ? "page" : "false");
      pager.append(button);
    }
    pager.append(nav("\u2192", page + 1, page === pages));
  };

  const apply = () => {
    const filtered = items.filter(matches);
    const pages = Math.max(1, Math.ceil(filtered.length / pageSize));
    if (page > pages) page = pages;
    const start = (page - 1) * pageSize;
    const visible = new Set(filtered.slice(start, start + pageSize));
    for (const item of items) item.hidden = !visible.has(item);
    if (noResults) noResults.hidden = filtered.length > 0;
    if (count) count.textContent = filtered.length === 0 ? "" : `${filtered.length} post${filtered.length === 1 ? "" : "s"}`;
    renderPager(pages);
  };

  search?.addEventListener("input", () => {
    query = search.value.trim().toLowerCase();
    page = 1;
    apply();
  });

  for (const button of filters) {
    button.addEventListener("click", () => {
      category = button.dataset.mediaFilter ?? "all";
      page = 1;
      for (const other of filters) other.classList.toggle("isActive", other === button);
      apply();
    });
  }

  apply();
</script>
