    ],
  },
];

const installCmd = "curl -fsSL https://raw.githubusercontent.com/Garudex-Labs/caracal/main/install-console.sh | sh";
---

<section id="explore" class="docs-body" aria-label="Documentation overview">
  <div class="docs-body__inner">

    <section class="docs-flow" aria-labelledby="docs-flow-heading">
      <header class="docs-section__head docs-section__head--split">
        <div>
          <p class="docs-section__eyebrow">How it works</p>
          <h2 id="docs-flow-heading" class="docs-section__heading">Five steps between an agent and a resource</h2>
        </div>
        <p class="docs-section__lede">
          Agents call real APIs with real credentials, and standing secrets are how that goes wrong.
          Caracal swaps them for short-lived authority that policy approves first. Click through the flow.
        </p>
      </header>

      <div class="flow" data-flow>
        <div class="flow__steps" role="tablist" aria-label="Authority flow steps">
          {flow.map((stage, i) => (
            <button
              class={`flow__step${i === 0 ? " isActive" : ""}`}
              type="button"
              role="tab"
              id={`flow-tab-${stage.id}`}
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`flow-panel-${stage.id}`}
              data-flow-step={stage.id}
              style={`--tint: ${stage.tint}`}
            >
              <span class="flow__step-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={stage.icon} />
              </span>
              <span class="flow__step-label">{stage.title}</span>
            </button>
          ))}
        </div>

        {flow.map((stage, i) => (
          <div
            class="flow__panel"
            role="tabpanel"
            id={`flow-panel-${stage.id}`}
            aria-labelledby={`flow-tab-${stage.id}`}
            data-flow-panel={stage.id}
            style={`--tint: ${stage.tint}`}
            hidden={i !== 0}
          >
            <p class="flow__panel-num">Step {i + 1} of 5</p>
            <p class="flow__panel-detail">{stage.detail}</p>
            <a class="flow__panel-link" href={stage.href}>
              <span>{stage.linkText}</span>
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
        ))}
      </div>

      <div class="quickstart" data-quickstart>
        <span class="quickstart__label">Try it now</span>
        <code class="quickstart__cmd">{installCmd}</code>
        <button class="quickstart__copy" type="button" data-quickstart-copy aria-label="Copy install command">
          <svg class="quickstart__icon-copy" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.copy} />
          <svg class="quickstart__icon-check" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.check} />
        </button>
        <span class="quickstart__then">then <code>caracal up</code></span>
      </div>
    </section>

    <section class="docs-caps" aria-label="What you get">
      <div class="caps">
        {capabilities.map((cap) => (
          <a class="cap" href={cap.href} style={`--tint: ${cap.tint}`}>
            <span class="cap__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={cap.icon} />
            </span>
            <span class="cap__text">
              <span class="cap__title">{cap.title}</span>
              <span class="cap__body">{cap.body}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="docs-audiences" aria-labelledby="docs-audiences-heading">
      <header class="docs-section__head">
        <p class="docs-section__eyebrow">Find your path</p>
        <h2 id="docs-audiences-heading" class="docs-section__heading">Where are you starting from?</h2>
      </header>

      <div class="audiences" data-audiences>
        <div class="audiences__tabs" role="tablist" aria-label="Choose your path">
          {audiences.map((audience, i) => (
            <button
              class={`audiences__tab${i === 0 ? " isActive" : ""}`}
              type="button"
              role="tab"
              id={`aud-tab-${audience.id}`}
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`aud-panel-${audience.id}`}
              data-audience-tab={audience.id}
              style={`--tint: ${audience.tint}`}
            >
              <span class="audiences__tab-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={audience.icon} />
              </span>
              {audience.label}
            </button>
          ))}
        </div>

        {audiences.map((audience, i) => (
          <div
            class="audiences__panel"
            role="tabpanel"
            id={`aud-panel-${audience.id}`}
            aria-labelledby={`aud-tab-${audience.id}`}
            data-audience-panel={audience.id}
            style={`--tint: ${audience.tint}`}
            hidden={i !== 0}
          >
            <div class="audiences__intro">
              <p class="audiences__blurb">{audience.intro}</p>
              <a class="audiences__start" href={audience.start.href}>
                <span>{audience.start.title}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            </div>
            <ul class="audiences__links">
              {audience.links.map((link) => (
                <li>
                  <a class="audiences__link" href={link.href}>
                    <span>{link.title}</span>
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

  </div>
</section>

<script>
  const initTabs = (tabSelector: string, panelSelector: string, tabKey: string, panelKey: string) => {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(tabSelector));
    const panels = Array.from(document.querySelectorAll<HTMLElement>(panelSelector));
    for (const tab of tabs) {
      tab.addEventListener("click", () => {
        const id = tab.dataset[tabKey];
        for (const other of tabs) {
          const active = other === tab;
          other.classList.toggle("isActive", active);
          other.setAttribute("aria-selected", String(active));
        }
        for (const panel of panels) panel.hidden = panel.dataset[panelKey] !== id;
      });
    }
  };

  initTabs("[data-flow-step]", "[data-flow-panel]", "flowStep", "flowPanel");
  initTabs("[data-audience-tab]", "[data-audience-panel]", "audienceTab", "audiencePanel");

  const copyButton = document.querySelector<HTMLButtonElement>("[data-quickstart-copy]");
  const cmd = document.querySelector<HTMLElement>(".quickstart__cmd");
  copyButton?.addEventListener("click", async () => {
    if (!cmd?.textContent) return;
    await navigator.clipboard.writeText(cmd.textContent);
    copyButton.classList.add("isCopied");
    setTimeout(() => copyButton.classList.remove("isCopied"), 1600);
  });
</script>
