---

<section id="explore" class="docs-body" aria-label="Documentation overview">
  <div class="docs-body__inner">

    <!-- Section 1: Value Proposition (What & Why) -->
    <section class="docs-value-prop" aria-labelledby="value-prop-heading">
      <div class="docs-value-prop__grid">
        <div class="docs-value-prop__content">
          <p class="docs-section__eyebrow">The Guardrails for Agentic Workloads</p>
          <h2 id="value-prop-heading" class="docs-section__heading">Why Caracal?</h2>
          <p class="docs-value-prop__text">
            As AI agents transition from read-only assistants to autonomous executors, they gain access to highly sensitive tools: databases, financial ledgers, and workspace APIs. Traditional post-execution auditing is reactive—it logs damage after it occurs. 
          </p>
          <p class="docs-value-prop__text">
            <strong>Caracal is pre-execution authority infrastructure.</strong> By intercepting tool execution *before* it happens, validating requests against Open Policy Agent (OPA) rules, and tracking delegation lines, Caracal brings enterprise-grade security and ironclad identity binding to autonomous agent runtimes.
          </p>
        </div>
        <div class="docs-value-prop__card">
          <h3 class="docs-value-prop__card-title">Traditional IAM vs. Caracal</h3>
          <ul class="docs-value-prop__list">
            <li>
              <strong>Static Identity:</strong> Static API keys can be leaked or abused. Caracal uses short-lived, single-use mandates.
            </li>
            <li>
              <strong>Post-Audit:</strong> Recording actions after execution is too late. Caracal blocks unauthorized actions before dispatch.
            </li>
            <li>
              <strong>Delegation Blindness:</strong> Standard security loses track when one agent spawns another. Caracal enforces cryptographic trust boundaries.
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Section 2: Core Capabilities -->
    <section class="docs-capabilities" aria-labelledby="capabilities-heading">
      <header class="docs-section__head">
        <p class="docs-section__eyebrow">Capabilities</p>
        <h2 id="capabilities-heading" class="docs-section__heading">Platform Capabilities</h2>
      </header>
      <div class="docs-capabilities__grid">
        {capabilities.map((cap) => (
          <div class="capability-card">
            <span class="capability-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={cap.icon} />
            </span>
            <h3 class="capability-card__title">{cap.title}</h3>
            <p class="capability-card__description">{cap.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Section 3: Navigation Pathways by Persona -->
    <section class="docs-paths" aria-labelledby="docs-paths-heading">
      <header class="docs-section__head">
        <p class="docs-section__eyebrow">Documentation Pathways</p>
        <h2 id="docs-paths-heading" class="docs-section__heading">Where do you want to begin?</h2>
      </header>

      <div class="docs-paths__grid">
        {paths.map((path) => (
          <article class="path-card">
            <span class="path-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={path.icon} />
            </span>
            <p class="path-card__kicker">{path.kicker}</p>
            <h3 class="path-card__title">{path.title}</h3>
            <p class="path-card__body">{path.body}</p>
            <ul class="path-card__links">
              {path.links.map((link) => (
                <li>
                  <a class="path-card__link" href={link.href}>
                    <span>{link.title}</span>
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <!-- Section 4: Curated Showcase -->
    <section class="docs-showcase" aria-labelledby="showcase-heading">
      <header class="docs-section__head">
        <p class="docs-section__eyebrow">Featured Resources</p>
        <h2 id="showcase-heading" class="docs-section__heading">Featured Content & Community</h2>
      </header>

      <div class="docs-showcase__grid">
        {/* Implementation Showcase */}
        <article class="showcase-card showcase-card--highlight">
          <div class="showcase-card__content">
            <span class="showcase-card__badge">Reference Lab</span>
            <h3 class="showcase-card__title">Lynx Capital</h3>
            <p class="showcase-card__description">
              See Caracal in action. Lynx Capital is a fully functional reference application demonstrating secure agentic investing. Witness how OPA policies regulate stock transactions, enforce delegation limits on sub-agents, and log verification trails.
            </p>
            <a href="/examples/lynx-capital/" class="showcase-card__link">
              <span>Explore Lynx Capital</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
        </article>

        {/* Featured Blog */}
        <article class="showcase-card">
          <div class="showcase-card__content">
            <span class="showcase-card__badge">Featured Blog</span>
            <h3 class="showcase-card__title">Pre-Execution Auth vs. Post-Execution Monitoring</h3>
            <p class="showcase-card__description">
              Why traditional post-execution auditing falls short in agent runtimes and how intercepting tool calls secures your APIs.
            </p>
            <a href="/blogs/" class="showcase-card__link">
              <span>Read the Blog</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
        </article>

        {/* Featured Vlog */}
        <article class="showcase-card">
          <div class="showcase-card__content">
            <span class="showcase-card__badge">Featured Vlog</span>
            <h3 class="showcase-card__title">Getting Started with Caracal in 5 Minutes</h3>
            <p class="showcase-card__description">
              Watch this quick video walkthrough to spin up the Caracal stack locally and protect your first HTTP API route.
            </p>
            <a href="/vlogs/" class="showcase-card__link">
              <span>Watch Video</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
        </article>
      </div>
    </section>

  </div>
</section>
