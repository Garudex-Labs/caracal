const flow = [
  {
    id: "request",
    icon: icons.send,
    tint: "#60a5fa",
    title: "Request",
    detail: "Your agent asks for authority right when it needs it. Nothing sits in code or env files waiting to leak.",
    href: "/concepts/principal/",
    linkText: "Identities and Applications",
  },
  {
    id: "decide",
    icon: icons.scale,
    tint: "#a78bfa",
    title: "Decide",
    detail: "Rego policy looks at the request and says yes or no before anything touches the resource.",
    href: "/concepts/policy/",
    linkText: "Policies and Policy Sets",
  },
  {
    id: "issue",
    icon: icons.ticket,
    tint: "#ec4899",
    title: "Issue",
    detail: "STS signs a short-lived mandate scoped to that app, that resource, that action. It expires on its own.",
    href: "/concepts/mandate/",
    linkText: "Mandates",
  },
  {
    id: "enforce",
    icon: icons.shield,
    tint: "#34d399",
    title: "Enforce",
    detail: "The Gateway checks the mandate and makes the call. No mandate, no call.",
    href: "/services/gateway/",
    linkText: "The Gateway",
  },
  {
    id: "record",
    icon: icons.scroll,
    tint: "#fbbf24",
    title: "Record",
    detail: "Audit keeps the whole story: who asked, what policy said, what actually happened.",
    href: "/concepts/audit-ledger/",
    linkText: "Audit and Request Traces",
  },
];

const capabilities = [
  {
    icon: icons.branch,
    tint: "#a78bfa",
    title: "Delegation that narrows",
    body: "Agents hand authority to sub-agents, and constraints can only shrink it.",
    href: "/concepts/delegation/",
  },
  {
    icon: icons.slash,
    tint: "#f87171",
    title: "Revoke from one place",
    body: "Kill active authority across every session without redeploying anything.",
    href: "/concepts/sessions-revocation/",
  },
  {
    icon: icons.code,
    tint: "#60a5fa",
    title: "Fits your stack",
    body: "TypeScript, Python, and Go SDKs, plus connectors for Express, MCP, and more.",
    href: "/sdks/",
  },
  {
    icon: icons.box,
    tint: "#34d399",
    title: "Deploys anywhere",
    body: "Local stack in one command, Docker Compose and Helm for everything else.",
    href: "/operations/",
  },
];

const audiences = [
  {
    id: "new",
    label: "I'm new here",
    icon: icons.compass,
    tint: "#60a5fa",
    intro: "You want to see it run before you read theory. Install the stack, protect one call, then dig into how it works.",
    start: { title: "What is Caracal?", href: "/get-started/" },
    links: [
      { title: "Install Caracal", href: "/get-started/install-caracal/" },
      { title: "First protected call", href: "/get-started/first-protected-call/" },
      { title: "One-Minute Model", href: "/concepts/model-overview/" },
      { title: "Add SDK to your app", href: "/get-started/add-sdk-to-your-app/" },
      { title: "First-run troubleshooting", href: "/get-started/first-run-troubleshooting/" },
    ],
  },
  {
    id: "building",
    label: "I'm building",
    icon: icons.wrench,
    tint: "#a78bfa",
    intro: "You have an app and an agent. Wire in the SDK, write your first policy, and watch authority flow through it.",
    start: { title: "Model your application", href: "/guides/modeling-recipes/" },
    links: [
      { title: "Author a Rego policy", href: "/guides/author-policy/" },
      { title: "Protect your first real API", href: "/tutorials/protect-an-api/" },
      { title: "Multi-agent delegation", href: "/guides/delegation/" },
      { title: "Tail the audit stream", href: "/guides/audit-stream/" },
      { title: "TypeScript SDK", href: "/sdks/typescript/" },
    ],
  },
  {
    id: "operating",
    label: "I run the platform",
    icon: icons.server,
    tint: "#34d399",
    intro: "You keep this thing healthy. Deployment options, production hardening, and what to check when something breaks.",
    start: { title: "Operations guide", href: "/operations/" },
    links: [
      { title: "Deploy with Docker Compose", href: "/operations/docker-compose/" },
      { title: "Deploy with Helm", href: "/operations/kubernetes-helm/" },
      { title: "Harden production", href: "/operations/tls-hardening/" },
      { title: "Monitor health and metrics", href: "/operations/observability/" },
      { title: "Troubleshoot by symptom", href: "/operations/troubleshooting/" },
    ],
  },
  {
    id: "contributing",
    label: "I want to contribute",
    icon: icons.heart,
    tint: "#ec4899",
    intro: "Caracal is built in the open and good PRs land fast. Set up locally, learn the architecture, find your first change.",
    start: { title: "Contribute to Caracal", href: "/contributing/" },
    links: [
      { title: "Set up locally", href: "/contributing/setup/" },
      { title: "Understand the architecture", href: "/architecture/" },
      { title: "Review the threat model", href: "/security/threat-model/" },
