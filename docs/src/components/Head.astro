//
// Head override that injects the mermaid diagram renderer with zoom controls.

import Default from '@astrojs/starlight/components/Head.astro'

const site = 'https://docs.caracal.run'
const pagePath = Astro.url.pathname.replace(/^\/|\/$/g, '') || 'index'
const markdownUrl = new URL(`markdown/${pagePath}.md`, `${site}/`).href
const hasMarkdown = pagePath !== '404'
---

<Default {...Astro.props} />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
<meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large" />
<link rel="alternate" type="text/plain" href={`${site}/llms.txt`} title="Caracal LLM discovery" />
<link rel="alternate" type="text/plain" href={`${site}/llms-full.txt`} title="Caracal full Markdown corpus" />
<link rel="alternate" type="application/json" href={`${site}/page-index.json`} title="Caracal page metadata index" />
{hasMarkdown && <link rel="alternate" type="text/markdown" href={markdownUrl} />}
<script>
  import mermaid from 'mermaid'

  const STEP = 0.25
  const MIN = 0.25
  const MAX = 4.0
  let mermaidRender = Promise.resolve()

  function isDark() {
    return document.documentElement.dataset.theme !== 'light'
  }

  function clearZoomControls() {
    document.querySelectorAll('.mermaid-zoom-bar').forEach((b) => b.remove())
    document.querySelectorAll('.mermaid-viewport').forEach((viewport) => {
      const parent = viewport.parentElement
      if (!parent) return
      while (viewport.firstChild) parent.insertBefore(viewport.firstChild, viewport)
      viewport.remove()
    })
  }

  function mountZoomControls() {
    clearZoomControls()

    document.querySelectorAll('.mermaid-diagram').forEach((container) => {
      const svg = container.querySelector('svg')
      if (!svg) return

      const diagram = svg.closest<HTMLElement>('.mermaid') ?? svg
      const baseW = svg.getBoundingClientRect().width || parseFloat(svg.getAttribute('width') ?? '800') || 800
      const baseH = svg.getBoundingClientRect().height || parseFloat(svg.getAttribute('height') ?? '400') || 400
      const viewport = document.createElement('div')
      let scale = 1.0

      viewport.className = 'mermaid-viewport'
      viewport.style.height = `${Math.min(Math.max(Math.ceil(baseH) + 16, 220), 560)}px`
      diagram.parentNode?.insertBefore(viewport, diagram)
      viewport.appendChild(diagram)

      svg.style.width = `${Math.ceil(baseW)}px`
      svg.style.height = `${Math.ceil(baseH)}px`
      svg.style.maxWidth = 'none'

      const bar = document.createElement('div')
      bar.className = 'mermaid-zoom-bar'
      bar.innerHTML =
        '<button class="mermaid-zoom-btn" aria-label="Zoom out" title="Zoom out">\u2212</button>' +
        '<button class="mermaid-zoom-btn mermaid-zoom-reset" aria-label="Reset zoom" title="Reset">\u2715</button>' +
        '<button class="mermaid-zoom-btn" aria-label="Zoom in" title="Zoom in">+</button>'

      const [btnOut, btnReset, btnIn] = bar.querySelectorAll<HTMLButtonElement>('button')

      function applyZoom() {
        diagram.style.width = `${Math.round(baseW * scale)}px`
        diagram.style.height = `${Math.round(baseH * scale)}px`
        diagram.style.maxWidth = 'none'
        svg.style.transform = `scale(${scale})`
        btnOut.disabled = scale <= MIN
        btnIn.disabled = scale >= MAX
        btnReset.dataset.active = scale === 1.0 ? '' : 'true'
      }

      btnIn.addEventListener('click', () => {
        scale = Math.min(MAX, +(scale + STEP).toFixed(2))
        applyZoom()
      })
      btnOut.addEventListener('click', () => {
        scale = Math.max(MIN, +(scale - STEP).toFixed(2))
        applyZoom()
      })
      btnReset.addEventListener('click', () => {
        scale = 1.0
        applyZoom()
      })

      applyZoom()
      container.prepend(bar)
    })
  }

  async function renderMermaid() {
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark() ? 'dark' : 'default',
      securityLevel: 'loose',
    })
    const nodes = [...document.querySelectorAll('.mermaid:not([data-processed])')]
    if (nodes.length) {
      clearZoomControls()
      nodes.forEach((node) => {
        if (!node.dataset.source) node.dataset.source = node.textContent ?? ''
      })
      await mermaid.run({ nodes })
    }
    mountZoomControls()
  }

  function initMermaid() {
    mermaidRender = mermaidRender.then(renderMermaid, renderMermaid)
    mermaidRender.catch((err) => console.error('Mermaid render failed', err))
  }

  document.addEventListener('DOMContentLoaded', initMermaid)
  document.addEventListener('astro:page-load', initMermaid)

  const observer = new MutationObserver(() => {
    document.querySelectorAll<HTMLElement>('.mermaid[data-source]').forEach((el) => {
      el.removeAttribute('data-processed')
      el.textContent = el.dataset.source ?? ''
    })
    initMermaid()
  })
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] })
</script>
