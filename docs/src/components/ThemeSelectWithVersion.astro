import ThemeSelect from './ThemeSelect.astro'
import VersionSelect from './VersionSelect.astro'
---

<div class="header-controls">
  <VersionSelect />
  <ThemeSelect />
</div>

<style>
  .header-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  @media (max-width: 30rem) {
    .header-controls {
      gap: 0.35rem;
    }
  }
</style>
