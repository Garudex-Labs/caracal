    "@react-three/fiber": "^9.6.1",
    "astro": "^7.0.7",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "4.0.1",
    "starlight-versions": "0.9.1",
    "three": "^0.185.1"
