# Caracal OSS environment template

# DEFAULTS
CARACAL_ENV_MODE=dev # dev|staging|prod
LOG_LEVEL=INFO # DEBUG|INFO|WARNING|ERROR|CRITICAL
CARACAL_MODE=user # user|dev

CARACAL_API_PORT=8000
CARACAL_API_URL=http://localhost:8000
CARACAL_ENTERPRISE_URL=
CARACAL_GATEWAY_ENABLED=false

CARACAL_DB_HOST=localhost
CARACAL_DB_PORT=5432
CARACAL_DB_NAME=caracal
CARACAL_DB_USER=caracal
CARACAL_DB_POOL_SIZE=10
CARACAL_DB_MAX_OVERFLOW=5
CARACAL_DB_POOL_TIMEOUT=30

REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=false # true|false

ENABLE_REDIS=true # true|false
ENABLE_MERKLE=false # true|false

CARACAL_PRINCIPAL_KEY_BACKEND=vault # vault

# REQUIRED
CARACAL_DB_PASSWORD=caracal_dev_password_CHANGE_ME
CARACAL_VAULT_URL=http://vault:8080
CARACAL_VAULT_TOKEN=dev-local-token
CARACAL_VAULT_PROJECT_ID=caracal
CARACAL_VAULT_ENVIRONMENT=dev
CARACAL_VAULT_SECRET_PATH=/
CARACAL_VAULT_SIGNING_KEY_REF=keys/mandate-signing
CARACAL_VAULT_SESSION_PUBLIC_KEY_REF=keys/session-public
CARACAL_SESSION_SIGNING_ALGORITHM=RS256 # RS256|ES256
CARACAL_VAULT_MODE=managed # managed

# Bootstrap credentials used by local OSS Infisical token/project recovery
CARACAL_VAULT_BOOTSTRAP_EMAIL=admin@caracal.local
CARACAL_VAULT_BOOTSTRAP_PASSWORD=CaracalVaultDev123!
CARACAL_VAULT_BOOTSTRAP_ORGANIZATION=caracal-local
CARACAL_VAULT_BOOTSTRAP_PROJECT_SLUG=caracal

# OPTIONAL
CARACAL_VAULT_RETRY_MAX_ATTEMPTS=3
CARACAL_VAULT_RETRY_BACKOFF_SECONDS=0.2
CARACAL_VAULT_SIDECAR_IMAGE=infisical/infisical:latest
CARACAL_VAULT_SIDECAR_PORT=8080
CARACAL_VAULT_SIDECAR_AUTH_SECRET=caracal-dev-auth-secret
CARACAL_VAULT_SIDECAR_ENCRYPTION_KEY=f13dbc92aaaf86fa7cb0ed8ac3265f47
CARACAL_VAULT_SIDECAR_REDIS_URL=redis://redis:6379
# URL-encode password if it contains special chars.
CARACAL_VAULT_SIDECAR_DB_CONNECTION_URI=postgresql://caracal:caracal_dev_password_CHANGE_ME@postgres:5432/caracal
CARACAL_VAULT_SIDECAR_SITE_URL=http://localhost:8080

CARACAL_KEYSTORE_DIR=
CARACAL_DB_SCHEMA=
CARACAL_DATABASE_URL=

CARACAL_CONFIG_PATH=
CARACAL_MCP_LISTEN_ADDRESS=0.0.0.0:8080
MCP_SERVERS=

CARACAL_RUNTIME_IMAGE=ghcr.io/garudex-labs/caracal-runtime:latest
CARACAL_RUNTIME_NETWORK=caracal-runtime
CARACAL_DOCKER_COMPOSE_FILE=
# Optional absolute host path mounted at /caracal-host-io inside runtime for workspace import/export files.
CARACAL_HOST_IO_DIR=

MERKLE_KEY_PASSPHRASE=
MERKLE_BATCH_SIZE_LIMIT=1000
MERKLE_BATCH_TIMEOUT_SECONDS=300
MERKLE_SIGNING_ALGORITHM=ECDSA-P256
