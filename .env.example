# Caracal environment configuration
# Copy to .env and fill in values before starting Caracal.
# Never commit secrets or real credentials.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Required
CARACAL_DB_HOST=localhost
CARACAL_DB_PORT=5432
CARACAL_DB_NAME=caracal
CARACAL_DB_USER=caracal
CARACAL_DB_PASSWORD=                    # Required — set a strong password

# Optional
CARACAL_DB_SCHEMA=                      # Isolate tables in a named schema (default: public)
CARACAL_DB_POOL_SIZE=10                 # Connection pool size
CARACAL_DB_MAX_OVERFLOW=5              # Max extra connections above pool_size
CARACAL_DB_POOL_TIMEOUT=30             # Seconds to wait for a pooled connection
CARACAL_DATABASE_URL=                   # Full DSN; overrides DB_* vars for Alembic migrations

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required (Redis is always enabled)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                         # Leave empty for unauthenticated Redis

# Alternative: provide a full Redis URL instead of REDIS_HOST/PORT/PASSWORD
# REDIS_URL=redis://localhost:6379/0

# ── Vault (Infisical) ─────────────────────────────────────────────────────────
# Required for all vault operations (mandate signing, session keys, secrets)
CARACAL_VAULT_URL=http://vault:8080
CARACAL_VAULT_TOKEN=                    # Required — service token issued by Infisical
CARACAL_VAULT_WORKSPACE_ID=            # Infisical workspace (project) ID
CARACAL_VAULT_ENVIRONMENT=prod         # dev | staging | prod
CARACAL_VAULT_MODE=managed             # managed | local (local for development only)
CARACAL_VAULT_SECRET_PATH=/            # Secret path prefix within the workspace (default: /)

# Vault key references (paths within the Infisical workspace)
CARACAL_VAULT_SIGNING_KEY_REF=keys/mandate-signing          # Mandate signing key
CARACAL_VAULT_SESSION_PUBLIC_KEY_REF=keys/session-public    # Session verification key
CARACAL_VAULT_MERKLE_SIGNING_KEY_REF=keys/merkle-signing    # Merkle tree signing key
CARACAL_VAULT_MERKLE_PUBLIC_KEY_REF=keys/merkle-signing-public

# Vault retry settings (optional)
CARACAL_VAULT_RETRY_MAX_ATTEMPTS=3
CARACAL_VAULT_RETRY_BACKOFF_SECONDS=0.2

# ── Session & principal signing ───────────────────────────────────────────────
CARACAL_SESSION_SIGNING_ALGORITHM=RS256   # RS256 | ES256
CARACAL_PRINCIPAL_KEY_BACKEND=vault       # vault (only supported backend)

# ── API & TUI ─────────────────────────────────────────────────────────────────
CARACAL_API_PORT=8000                     # Port the Caracal API listens on
CARACAL_API_URL=http://localhost:8000     # External-facing API URL (used by TUI SDK bridge)
CARACAL_API_KEY=                          # API key for TUI ↔ API authentication (optional)
CARACAL_ENTERPRISE_URL=                   # Enterprise gateway URL (enterprise mode only)
CARACAL_GATEWAY_ENABLED=false             # Enable the gateway proxy (true | false)

# ── MCP adapter ───────────────────────────────────────────────────────────────
CARACAL_MCP_LISTEN_ADDRESS=0.0.0.0:8080  # Address the MCP adapter listens on
CARACAL_CONFIG_PATH=                      # Explicit path to config.yaml (default: workspace config)

# ── Runtime container ─────────────────────────────────────────────────────────
CARACAL_RUNTIME_IMAGE=ghcr.io/garudex-labs/caracal-runtime:latest
CARACAL_RUNTIME_NETWORK=caracal-runtime
CARACAL_DOCKER_COMPOSE_FILE=             # Override default docker-compose file path
CARACAL_HOST_IO_DIR=                     # Host path mounted at /caracal-host-io in the runtime container

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Deployment mode ───────────────────────────────────────────────────────────
CARACAL_MODE=user        # user | dev — controls TUI mode detection
CARACAL_ENV_MODE=prod    # dev | staging | prod — used by enterprise runtime components

# ── Merkle tree ───────────────────────────────────────────────────────────────
# Required only when using software Merkle signing with an encrypted key file.
# Leave empty if the key is unencrypted or when using vault signing (default).
MERKLE_KEY_PASSPHRASE=

# ── Local development bootstrap (NOT for production) ──────────────────────────
# These variables configure the local Infisical sidecar for development only.
# Do not set these in production — use a real Infisical instance instead.
#
# CARACAL_VAULT_BOOTSTRAP_EMAIL=admin@caracal.local
# CARACAL_VAULT_BOOTSTRAP_PASSWORD=
# CARACAL_VAULT_BOOTSTRAP_ORGANIZATION=caracal-local
# CARACAL_VAULT_BOOTSTRAP_PROJECT_SLUG=caracal
#
# CARACAL_VAULT_SIDECAR_IMAGE=infisical/infisical:latest
# CARACAL_VAULT_SIDECAR_PORT=8080
# CARACAL_VAULT_SIDECAR_AUTH_SECRET=          # Required for local sidecar
# CARACAL_VAULT_SIDECAR_ENCRYPTION_KEY=       # 32-char hex string — generate: openssl rand -hex 16
# CARACAL_VAULT_SIDECAR_REDIS_URL=redis://redis:6379
# CARACAL_VAULT_SIDECAR_DB_CONNECTION_URI=postgresql://caracal:<password>@postgres:5432/caracal
# CARACAL_VAULT_SIDECAR_SITE_URL=http://localhost:8080
