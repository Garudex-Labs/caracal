# Caracal, a product of Garudex Labs
#
# Copy to `.env` (gitignored) at the repo root. Every caracal command loads it - `up`, `web`,
# and `run` - so this is the single place to configure dev. Uncomment and edit any line;
# exported shell variables and secret managers still win over this file.

# --- caracal run (workload identity) ---
# CARACAL_WORKLOAD_ID=fiona
# CARACAL_STS_URL=http://localhost:8080
# Provide the secret inline, via a file, or the owner-only default under the config dir.
# CARACAL_WORKLOAD_SECRET=
# CARACAL_WORKLOAD_SECRET_FILE=

# --- Web console sign-in (auth) ---
# The OAuth callback origin follows how the console is served:
#   caracal up (packaged console, port 3001):  http://localhost:3001/api/auth/callback/<provider>
#   caracal web (dev console launcher, BFF on 3002): http://localhost:3002/api/auth/callback/<provider>
# Google allows several redirect URIs on one client; a GitHub OAuth app takes one
# callback URL, so use one app per mode there.
# Google: Cloud Console -> Credentials -> OAuth client ID (Web application).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GitHub: Settings -> Developer settings -> OAuth Apps.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Registration posture (open in dev, closed in production by default).
# CARACAL_OPEN_REGISTRATION=false
# CARACAL_PASSWORD_SIGNUP=true
# SMTP for password reset and sign-up verification (honours the _FILE convention).
# CARACAL_SMTP_URL=smtps://user:password@smtp.example.com:465
# CARACAL_SMTP_FROM="Caracal <no-reply@example.com>"

# --- Stack overrides (compose) ---
# LOG_LEVEL=debug
# CARACAL_APP_MEM_LIMIT=1G
# CARACAL_DB_MEM_LIMIT=2G
# REDIS_MAXMEMORY=1gb
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
