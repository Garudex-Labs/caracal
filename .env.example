# Caracal environment configuration
# Copy to .env and fill in values before starting Caracal.
# Never commit secrets or real credentials.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Required
CCL_DB_HOST=localhost
CCL_DB_PORT=5432
CCL_DB_USER=caracal
CCL_DB_PASS=                    # Required — set a strong password

# Optional
CCL_DB_SCHEMA=                      # Isolate tables in a named schema (default: public)
CCL_DB_POOL_SIZE=10                 # Connection pool size
CCL_DB_MAX_OVFL=5              # Max extra connections above pool_size
CCL_DB_POOL_TTL=30             # Seconds to wait for a pooled connection
CCL_DB_URL=                   # Full DSN; overrides DB_* vars for Alembic migrations

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required (Redis is always enabled)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                         # Leave empty for unauthenticated Redis

# Alternative: provide a full Redis URL instead of REDIS_HOST/PORT/PASSWORD
# REDIS_URL=redis://localhost:6379/0

# ── Vault (Infisical) ─────────────────────────────────────────────────────────
# Required for all vault operations (mandate signing, session keys, secrets)
CCL_VAULT_URL=http://vault:8080
CCL_VAULT_TOKEN=                    # Required — service token issued by Infisical
CCL_VAULT_WS_ID=            # Infisical workspace (project) ID
CCL_VAULT_ENV=prod         # dev | staging | prod
CCL_VAULT_MODE=managed             # managed | local (local for development only)
CCL_VAULT_PATH=/            # Secret path prefix within the workspace (default: /)

# Vault key references (paths within the Infisical workspace)
CCL_VAULT_SIGN_KEY=keys/mandate-signing          # Mandate signing key
CCL_VAULT_SESS_KEY=keys/session-public    # Session verification key
CCL_VAULT_MERKLE_KEY=keys/merkle-signing    # Merkle tree signing key
CCL_VAULT_MERKLE_PUB=keys/merkle-signing-public

# Vault retry settings (optional)
CCL_VAULT_RETRY_MAX=3
CCL_VAULT_RETRY_SEC=0.2

# ── Session & principal signing ───────────────────────────────────────────────
CCL_SESSION_ALG=RS256   # RS256 | ES256
CCL_KEY_BACKEND=vault       # vault (only supported backend)

# ── API & TUI ─────────────────────────────────────────────────────────────────
CCL_API_PORT=8000                     # Port the Caracal API listens on
CCL_API_URL=http://localhost:8000     # External-facing API URL (used by TUI SDK bridge)
# CCL_API_KEY is auto-generated by `caracal bootstrap`. Run `caracal auth
# token` to print it. Do not set it here.
CCLE_URL=                   # Enterprise gateway URL (enterprise mode only)
CCL_GW_ENABLED=false             # Enable the gateway proxy (true | false)

# ── MCP adapter ───────────────────────────────────────────────────────────────
CCL_MCP_ADDR=0.0.0.0:8080  # Address the MCP adapter listens on
CCL_CONFIG_PATH=                      # Explicit path to config.yaml (default: workspace config)

# ── Runtime container ─────────────────────────────────────────────────────────
CCL_RUNTIME_IMG=ghcr.io/garudex-labs/caracal-runtime:latest
CCL_RUNTIME_NET=caracal-runtime
CCL_COMPOSE_FILE=             # Override default docker-compose file path
CCL_HOST_IO_DIR=                     # Host path mounted at /caracal-host-io in the runtime container

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Deployment mode ───────────────────────────────────────────────────────────
CCL_MODE=user        # user | dev — controls TUI mode detection
CCL_ENV_MODE=prod    # dev | staging | prod — used by enterprise runtime components

# ── Merkle tree ───────────────────────────────────────────────────────────────
# Required only when using software Merkle signing with an encrypted key file.
# Leave empty if the key is unencrypted or when using vault signing (default).
MERKLE_KEY_PASSPHRASE=

# ── Local development bootstrap (NOT for production) ──────────────────────────
# These variables configure the local Infisical sidecar for development only.
# Do not set these in production — use a real Infisical instance instead.
#
# CCL_VAULT_BS_EMAIL=admin@caracal.local
# CCL_VAULT_BS_PASS=
# CCL_VAULT_BS_ORG=caracal-local
# CCL_VAULT_BS_PROJ=caracal
# CCL_VAULT_ID_TOKEN=   # Auto-written on first bootstrap; do not set manually
#
# VAULT_IMAGE=infisical/infisical:v0.93.1
# VAULT_PORT=8080
# VAULT_AUTH_SECRET=          # Required for local sidecar
# VAULT_ENC_KEY=       # 32-char hex string — generate: openssl rand -hex 16
# VAULT_REDIS_URL=redis://redis:6379
# VAULT_DB_URL=postgresql://caracal:<password>@postgres:5432/caracal_vault
# VAULT_SITE_URL=http://localhost:8080

# ── Postgres multi-DB init ────────────────────────────────────────────────────
# Path to postgres init scripts directory. Auto-set by `caracal up`.
# Override to use custom init scripts.
CCL_PG_INIT_DIR=

# ── Internal runtime state ────────────────────────────────────────────────────
# CCL_AIS_NONCE, CCL_AIS_ATTEST_PID,
# CCL_SESSION_HMAC, and CCL_API_KEY are managed entirely
# by `caracal bootstrap` and live in $CCL_HOME/runtime/.env. Do not set
# them here.
