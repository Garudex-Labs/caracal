# Caracal Core - Environment Variables Example
# Copy this file to .env and customize for your environment
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker-compose up -d

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Canonical Caracal PostgreSQL variables
CARACAL_DB_HOST=localhost
CARACAL_DB_PORT=5432
CARACAL_DB_NAME=caracal
CARACAL_DB_USER=caracal
CARACAL_DB_PASSWORD=caracal_dev_password_CHANGE_ME

# Database connection pool size
CARACAL_DB_POOL_SIZE=10

# Maximum overflow connections beyond pool size
CARACAL_DB_MAX_OVERFLOW=5

# Connection pool timeout in seconds
CARACAL_DB_POOL_TIMEOUT=30

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis password (CHANGE THIS IN PRODUCTION!)
REDIS_PASSWORD=caracal_redis_password_CHANGE_ME

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis database number (default: 0)
REDIS_DB=0

# Enable Redis SSL/TLS (true/false)
REDIS_SSL=false

# Metrics cache TTL in seconds (default: 3600 = 1 hour)
REDIS_METRICS_CACHE_TTL=3600

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# Public broker API host port (maps host -> MCP container :8080)
CARACAL_API_PORT=8000

# Enable Redis caching (recommended for performance)
ENABLE_REDIS=true

# Enable Merkle trees (cryptographic audit trails for compliance)
ENABLE_MERKLE=false

# =============================================================================
# MERKLE TREE CONFIGURATION (Optional - only if ENABLE_MERKLE=true)
# =============================================================================
# NOTE: Merkle trees provide cryptographic audit trails
# Only needed for compliance/audit requirements
#
# # Batch size limit (number of events per batch)
# MERKLE_BATCH_SIZE_LIMIT=1000
# 
# # Batch timeout in seconds (close batch after this time)
# MERKLE_BATCH_TIMEOUT_SECONDS=300
# 
# # Signing algorithm: ECDSA-P256
# MERKLE_SIGNING_ALGORITHM=ECDSA-P256

# =============================================================================
# MCP ADAPTER CONFIGURATION
# =============================================================================

# Shared endpoint for SDK clients
CARACAL_API_URL=http://localhost:8000

# Optional: runtime network used by the open-source stack
CARACAL_RUNTIME_NETWORK=caracal-runtime

# Optional: remote enterprise API base URL (hosted endpoint).
# No default is provided to avoid local coupling assumptions.
CARACAL_ENTERPRISE_URL=

# Optional dev-only override for local enterprise integration tests.
# Applied only when CARACAL_ENV_MODE=dev.
CARACAL_ENTERPRISE_DEV_URL=

# Legacy alias: prefer CARACAL_ENTERPRISE_URL.
CARACAL_GATEWAY_URL=

# Legacy endpoint alias used by older gateway feature-flag paths.
CARACAL_GATEWAY_ENDPOINT=

# Enable remote enterprise gateway enforcement (true/false)
CARACAL_GATEWAY_ENABLED=false

# MCP servers configuration (format: name1:url1,name2:url2)
# Example: MCP_SERVERS=local:http://localhost:3000,remote:http://mcp-server:3001
MCP_SERVERS=

# MCP server timeout in seconds
MCP_SERVER_TIMEOUT=30

# =============================================================================
# RUNTIME ENVIRONMENT MODES
# =============================================================================

# Runtime environment mode: dev, staging, prod
CARACAL_ENV_MODE=dev

# Enable DEBUG logs (effective only when CARACAL_ENV_MODE=dev)
CARACAL_DEBUG_LOGS=false

# Force JSON logs in dev mode (staging/prod always JSON)
CARACAL_JSON_LOGS=false

# Runtime container image used by image-only deployments
CARACAL_RUNTIME_IMAGE=ghcr.io/garudex-labs/caracal-runtime:latest

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Enable Prometheus metrics export (true/false)
ENABLE_PROMETHEUS_METRICS=true

# Enable structured JSON logging (true/false)
ENABLE_STRUCTURED_LOGGING=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# In staging/prod, DEBUG is automatically downgraded to INFO.
LOG_LEVEL=INFO
