{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Garudex-Labs/caracal/releases/schema/manifest.schema.json",
  "title": "Caracal release manifest",
  "type": "object",
  "required": [
    "release",
    "mode",
    "version",
    "generatedAt",
    "binaries",
    "runtimeImage",
    "containers",
    "helm",
    "images",
    "pypi",
    "npm",
    "packages",
    "githubRelease"
  ],
  "dependentRequired": {
    "sha": ["source"],
    "source": ["sha"]
  },
  "properties": {
    "release": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(-rc\\..+)?$"
    },
    "mode": {
      "type": "string",
      "enum": ["rc", "stable"]
    },
    "publishedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "version": { "type": "string" },
    "promotedFrom": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"
    },
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "generatedAt": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": ["gitSha", "dirty"],
      "properties": {
        "gitSha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "dirty": { "const": false }
      },
      "additionalProperties": false
    },
    "registries": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "binaries": {
      "type": "object",
      "required": ["runtime"],
      "additionalProperties": { "type": "string" }
    },
    "runtimeImage": { "type": "string" },
    "containers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "helm": {
      "type": "object",
      "required": ["chartVersion", "appVersion", "imageTag"],
      "properties": {
        "chartVersion": { "type": "string" },
        "appVersion": { "type": "string" },
        "imageTag": { "type": "string" }
      },
      "additionalProperties": false
    },
    "images": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "imageDigests": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      }
    },
    "pypi": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "npm": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "packages": {
      "type": "object",
      "required": ["published", "unchanged"],
      "properties": {
        "published": {
          "type": "object",
          "required": ["pypi", "npm", "go"],
          "properties": {
            "pypi": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "npm": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "go": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "unchanged": {
          "type": "object",
          "required": ["pypi", "npm", "go"],
          "properties": {
            "pypi": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "npm": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "go": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "githubRelease": {
      "oneOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "required": ["tag", "assets"],
          "properties": {
            "tag": { "type": "string" },
            "assets": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
