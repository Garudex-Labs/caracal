# Lynx Capital — workload environment (the running application)
#
# Copy to .env and fill in. These are the only Caracal variables the application reads at
# runtime. Provisioning the zone (creating the applications, providers, resource views, and
# policy set) uses a separate operator file, .env.provision — never mix the two.

# The zone that owns the applications, providers, resource views, and policy set.
CARACAL_ZONE_ID=<zone-id>

# One managed application per permission boundary. scripts/provision.py creates them and
# writes the generated values to config/provisioned.env; each client secret is returned
# exactly once at creation. The swarm process loads all seven, and each boundary's agents
# present only that boundary's authority. Application ids may also come from
# config/provisioned.json; secrets only ever come from the environment.
LYNX_CARACAL_OPERATIONS_APPLICATION_ID=<lynx-operations-application-id>
LYNX_CARACAL_OPERATIONS_CLIENT_SECRET=<lynx-operations-client-secret>
LYNX_CARACAL_INTAKE_APPLICATION_ID=<lynx-intake-application-id>
LYNX_CARACAL_INTAKE_CLIENT_SECRET=<lynx-intake-client-secret>
LYNX_CARACAL_LEDGER_APPLICATION_ID=<lynx-ledger-application-id>
LYNX_CARACAL_LEDGER_CLIENT_SECRET=<lynx-ledger-client-secret>
LYNX_CARACAL_COMPLIANCE_APPLICATION_ID=<lynx-compliance-application-id>
LYNX_CARACAL_COMPLIANCE_CLIENT_SECRET=<lynx-compliance-client-secret>
LYNX_CARACAL_TREASURY_APPLICATION_ID=<lynx-treasury-application-id>
LYNX_CARACAL_TREASURY_CLIENT_SECRET=<lynx-treasury-client-secret>
LYNX_CARACAL_PAYMENTS_APPLICATION_ID=<lynx-payments-application-id>
LYNX_CARACAL_PAYMENTS_CLIENT_SECRET=<lynx-payments-client-secret>
LYNX_CARACAL_AUDIT_APPLICATION_ID=<lynx-audit-application-id>
LYNX_CARACAL_AUDIT_CLIENT_SECRET=<lynx-audit-client-secret>

# --- Optional service overrides -----------------------------------------------
# Only set these when the platform services are not at their defaults.
# CARACAL_STS_URL=http://localhost:8080
# CARACAL_GATEWAY_URL=http://localhost:8081
# CARACAL_COORDINATOR_URL=http://localhost:4000

# --- Optional agent lifecycle tuning --------------------------------------------
# TTL for spawned worker sessions and minted resource mandates, in seconds.
# LYNX_WORKER_TTL_SECONDS=600
# LYNX_MANDATE_TTL_SECONDS=300

# --- Application configuration -------------------------------------------------
# Model provider key for the agent runtime.
OPENAI_API_KEY=sk-...

# Offline demo only. With Caracal unconfigured, provider access fails closed — no agent can
# reach a provider without Caracal. Set this to 1 to run the bundled demo against the local
# simulated provider surface instead. Never set it in a real deployment.
# LYNX_SIMULATION=1
