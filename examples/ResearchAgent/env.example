#
# Shell-compatible environment example for launching the ResearchAgent with caracal run.

# Copy this file outside the repo, replace the Console values, then source it:
#   cp env.example ~/.config/caracal/research-agent/env
#   . ~/.config/caracal/research-agent/env
#   caracal run -- node agent.mjs

# Do not put GOOGLE_DRIVE_ACCESS_TOKEN, GOOGLE_CALENDAR_ACCESS_TOKEN, or
# OPENAI_API_KEY in this file. Caracal injects those variables only into the
# launched agent process after STS authorizes the run.

export CARACAL_ZONE_ID="zone_prod"
export CARACAL_APPLICATION_ID="app_support_research_agent"
export CARACAL_RUN_TTL_SECONDS="900"
