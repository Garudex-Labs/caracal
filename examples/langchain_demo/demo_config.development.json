{
  "_config_version": "2.0",
  "_description": "Development configuration with verbose logging and debugging features",
  "caracal": {
    "base_url": "http://127.0.0.1:8080",
    "api_key_env": "CARACAL_API_KEY",
    "organization_id": null,
    "workspace_id": "langchain-demo-dev",
    "project_id": null
  },
  "modes": {
    "mock": {
      "source_mandate_id": "REPLACE_WITH_MOCK_SOURCE_MANDATE_ID",
      "revoker_id": "REPLACE_WITH_PRINCIPAL_ID_USED_FOR_REVOCATION",
      "principal_ids": {
        "orchestrator": "REPLACE_WITH_ORCHESTRATOR_PRINCIPAL_ID",
        "finance": "REPLACE_WITH_FINANCE_PRINCIPAL_ID",
        "ops": "REPLACE_WITH_OPS_PRINCIPAL_ID"
      },
      "mandates": {
        "orchestrator": "REPLACE_WITH_MOCK_ORCHESTRATOR_MANDATE_ID",
        "finance": "REPLACE_WITH_MOCK_FINANCE_MANDATE_ID",
        "ops": "REPLACE_WITH_MOCK_OPS_MANDATE_ID"
      }
    },
    "real": {
      "source_mandate_id": "REPLACE_WITH_REAL_SOURCE_MANDATE_ID",
      "revoker_id": "REPLACE_WITH_PRINCIPAL_ID_USED_FOR_REVOCATION",
      "principal_ids": {
        "orchestrator": "REPLACE_WITH_ORCHESTRATOR_PRINCIPAL_ID",
        "finance": "REPLACE_WITH_FINANCE_PRINCIPAL_ID",
        "ops": "REPLACE_WITH_OPS_PRINCIPAL_ID"
      },
      "mandates": {
        "orchestrator": "REPLACE_WITH_REAL_ORCHESTRATOR_MANDATE_ID",
        "finance": "REPLACE_WITH_REAL_FINANCE_MANDATE_ID",
        "ops": "REPLACE_WITH_REAL_OPS_MANDATE_ID"
      }
    }
  },
  "scenario": {
    "default_scenario": "default",
    "scenarios_path": null,
    "auto_load": true
  },
  "ui": {
    "host": "127.0.0.1",
    "port": 8000,
    "enable_websocket": true,
    "websocket_ping_interval": 30,
    "max_message_history": 5000,
    "enable_logs_panel": true,
    "enable_tool_panel": true,
    "enable_caracal_panel": true
  },
  "logging": {
    "level": "DEBUG",
    "format": "detailed",
    "log_to_file": true,
    "log_file_path": "logs/demo_dev.log",
    "max_file_size_mb": 50,
    "backup_count": 5
  },
  "mock_system": {
    "enabled": true,
    "config_path": null,
    "cache_responses": false,
    "simulate_delays": true,
    "default_llm_provider": "openai"
  },
  "agent": {
    "max_iterations": 20,
    "timeout_seconds": 600,
    "enable_sub_agents": true,
    "max_delegation_depth": 5
  }
}
