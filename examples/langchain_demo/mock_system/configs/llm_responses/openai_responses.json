{
  "version": "1.0",
  "provider": "openai",
  "description": "Mock OpenAI LLM responses for various prompts",
  "prompt_patterns": [
    {
      "pattern": ".*summarize.*",
      "response_template": "Summary: {summary_text}",
      "variables": {
        "summary_text": "Key points identified and consolidated"
      },
      "match_type": "regex"
    },
    {
      "pattern": ".*analyze.*",
      "response_template": "Analysis: {analysis_text}",
      "variables": {
        "analysis_text": "Detailed analysis completed with insights"
      },
      "match_type": "regex"
    },
    {
      "pattern": ".*recommend.*",
      "response_template": "Recommendations: {recommendations}",
      "variables": {
        "recommendations": "1. Take immediate action, 2. Monitor closely, 3. Follow up in 24 hours"
      },
      "match_type": "regex"
    }
  ]
}
