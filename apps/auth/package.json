{
  "name": "@caracalai/auth",
  "version": "0.2.0-rc.3",
  "private": true,
  "description": "Caracal Community Edition authentication service built on Better Auth.",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "start": "node dist/server.js",
    "migrate": "node dist/migrate.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. tests/typescript/unit/auth",
    "lint": "eslint ."
  },
  "dependencies": {
    "@caracalai/core": "workspace:*",
    "@caracalai/server-core": "workspace:*",
    "@caracalai/engine": "workspace:*",
    "better-auth": "^1.6.23",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  }
}
