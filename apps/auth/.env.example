# Caracal, a product of Garudex Labs
#
# Environment template for the auth service; copy to `.env` (gitignored) and fill in values.
#
# `caracal web` injects the port, web origin, database URL, signing secret, and allowlist
# path into the process environment, which takes precedence over this file; adjust those
# with launcher flags (`--auth-port`, `--web-port`) or shell exports, not here.

# --- Core ---
# Trust the first x-forwarded-for hop when running behind a reverse proxy.
# CARACAL_AUTH_TRUST_PROXY=true

# --- Operator registration ---
# Signed-in operators get control-plane admin, so restrict admission to trusted operators.
# Manage the allowlist on the stack host with `caracal allowlist` (exact emails or `@domain`
# suffixes); while it is empty, registration is open in development and closed in production.
# CARACAL_OPEN_REGISTRATION=false
# Email/password sign-up is disabled in production by default; enabling it there requires the
# SMTP transport below and verified email before sign-in.
# CARACAL_PASSWORD_SIGNUP=true

# --- Email delivery ---
# SMTP relay for password reset and production sign-up verification links; honours the `_FILE`
# secret convention. Without it, password reset is hidden in the web console.
# CARACAL_SMTP_URL=smtps://user:password@smtp.example.com:465
# CARACAL_SMTP_FROM="Caracal <no-reply@example.com>"

# --- Database ---
# TLS for managed Postgres: "require" (verify cert) or "no-verify" (self-signed).
# CARACAL_AUTH_DATABASE_SSL=require

# --- Google sign-in ---
# Google Cloud Console -> Credentials -> OAuth client ID (Web application)
# Authorized redirect URI: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub sign-in ---
# GitHub -> Settings -> Developer settings -> OAuth Apps
# Authorization callback URL: http://localhost:3002/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
