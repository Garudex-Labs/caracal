#
# Copy to `local.env` and uncomment any value below to override an `infra/docker/dev.env`
# default. The local override file is gitignored. Compose loads dev.env first, then
# local.env, so entries here win. Secrets are file-backed and never set here.

# CARACAL_STS_ISSUER_URL=http://localhost:8080
# STS_ADMIN_TOKEN=          # enables /internal/policy/status and key-rotation endpoints
# AUDIT_ADMIN_TOKEN=        # enables /api/audit/dlq browse, detail, and replay endpoints
# AUDIT_EXPORT_S3_ENDPOINT=https://s3.amazonaws.com
# AUDIT_EXPORT_S3_BUCKET=
# CARACAL_APP_MEM_LIMIT=1G
# CARACAL_DB_MEM_LIMIT=2G
# REDIS_MAXMEMORY=1gb
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# LOG_LEVEL=debug
