# Local-dev environment template. Copy to `.env` and fill in values.

POSTGRES_USER=caracal
POSTGRES_PASSWORD=changeMe
POSTGRES_DB=caracal

REDIS_PASSWORD=changeMe

CARACAL_ADMIN_TOKEN=changeMe

# 32-byte hex-encoded secrets. Generate with: openssl rand -hex 32
ZONE_KEK=
AUDIT_HMAC_KEY=
STREAMS_HMAC_KEY=

# Local-dev escape hatches: required for the local stack to start without TLS
# certificates and to expose the one-shot bootstrap route used by `caracal init`.
# Never enable these in a non-local environment.
INSECURE_STS=true
INSECURE_HTTP=true
CARACAL_LOCAL_BOOTSTRAP_ENABLED=true

# Optional: S3-compatible endpoint for audit Parquet export (leave blank to disable)
AUDIT_EXPORT_S3_ENDPOINT=
AUDIT_EXPORT_S3_BUCKET=

# Runtime tuning. All optional; sensible defaults are baked into docker-compose.yml.
# Apply per-service CPU/memory caps for app containers (sts, api, gateway, audit, coordinator).
CARACAL_APP_CPU_LIMIT=1.0
CARACAL_APP_MEM_LIMIT=512M
CARACAL_APP_MEM_RESERVE=128M

# Postgres tuning. Tune shared_buffers ≈ 25% of CARACAL_DB_MEM_LIMIT.
CARACAL_DB_CPU_LIMIT=2.0
CARACAL_DB_MEM_LIMIT=1G
CARACAL_DB_MEM_RESERVE=256M
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_LOG_MIN_DURATION_MS=500

# Redis tuning. REDIS_MAXMEMORY should be ≤ CARACAL_REDIS_MEM_LIMIT.
CARACAL_REDIS_CPU_LIMIT=1.0
CARACAL_REDIS_MEM_LIMIT=768M
CARACAL_REDIS_MEM_RESERVE=128M
REDIS_MAXMEMORY=512mb
