{
  "product": {
    "version": "0.2.0-rc.4",
    "binaries": {
      "runtime": {
        "sourceDir": "apps/runtime/dist",
        "sourceBase": "caracal",
        "binaryName": "caracal"
      }
    },
    "archiveTargets": [
      {
        "os": "linux",
        "arch": "amd64",
        "bunArch": "x64"
      },
      {
        "os": "linux",
        "arch": "arm64",
        "bunArch": "arm64"
      },
      {
        "os": "darwin",
        "arch": "amd64",
        "bunArch": "x64"
      },
      {
        "os": "darwin",
        "arch": "arm64",
        "bunArch": "arm64"
      },
      {
        "os": "windows",
        "arch": "amd64",
        "bunArch": "x64"
      }
    ],
    "containers": [
      {
        "name": "go",
        "context": ".",
        "dockerfile": "infra/docker/Dockerfile.go-service",
        "tier": "internal"
      },
      {
        "name": "node",
        "context": ".",
        "dockerfile": "infra/docker/Dockerfile.node-service",
        "tier": "runtime"
      },
      {
        "name": "web",
        "context": ".",
        "dockerfile": "infra/docker/Dockerfile.web",
        "tier": "runtime"
      },
      {
        "name": "postgres",
        "context": "infra/postgres",
        "dockerfile": "infra/postgres/Dockerfile",
        "tier": "internal"
      },
      {
        "name": "redis",
        "context": "infra/redis",
        "dockerfile": "infra/redis/Dockerfile",
        "tier": "internal"
      },
      {
        "name": "runtime",
        "context": ".",
        "dockerfile": "apps/runtime/Dockerfile",
        "tier": "runtime"
      }
    ],
    "helm": {
      "chart": "infra/helm/caracal/Chart.yaml",
      "values": "infra/helm/caracal/values.yaml"
    }
  },
  "packages": {
    "npm": [
      {
        "id": "core",
        "name": "@caracalai/core",
        "dir": "packages/core/ts",
        "group": "core",
        "tier": "core",
        "publish": true
      },
      {
        "id": "oauth",
        "name": "@caracalai/oauth",
        "dir": "packages/oauth/ts",
        "group": "oauth",
        "tier": "core",
        "publish": true
      },
      {
        "id": "admin",
        "name": "@caracalai/admin",
        "dir": "packages/admin/ts",
        "group": "admin",
        "tier": "sdk",
        "publish": true
      },
      {
        "id": "identity",
        "name": "@caracalai/identity",
        "dir": "packages/identity/ts",
        "group": "identity",
        "tier": "core",
        "publish": true
      },
      {
        "id": "revocation",
        "name": "@caracalai/revocation",
        "dir": "packages/revocation/ts",
        "group": "revocation",
        "tier": "core",
        "publish": true
      },
      {
        "id": "sdk",
        "name": "@caracalai/sdk",
        "dir": "packages/sdk/ts",
        "group": "sdk",
        "tier": "sdk",
        "publish": true
      },
      {
        "id": "verify",
        "name": "@caracalai/verify",
        "dir": "packages/verify/ts",
        "group": "verify",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "express",
        "name": "@caracalai/express",
        "dir": "packages/adapters/express/ts",
        "group": "express",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "fastmcp",
        "name": "@caracalai/fastmcp",
        "dir": "packages/adapters/fastmcp/ts",
        "group": "fastmcp",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "redis",
        "name": "@caracalai/revocation-redis",
        "dir": "packages/backends/redis/ts",
        "group": "revocation-redis",
        "tier": "connector",
        "publish": true
      }
    ],
    "pypi": [
      {
        "id": "core",
        "name": "caracalai-core",
        "dir": "packages/core/python",
        "module": "caracalai_core",
        "group": "core",
        "tier": "core",
        "publish": true
      },
      {
        "id": "oauth",
        "name": "caracalai-oauth",
        "dir": "packages/oauth/python",
        "module": "caracalai_oauth",
        "group": "oauth",
        "tier": "core",
        "publish": true
      },
      {
        "id": "admin",
        "name": "caracalai-admin",
        "dir": "packages/admin/python",
        "module": "caracalai_admin",
        "group": "admin",
        "tier": "sdk",
        "publish": true
      },
      {
        "id": "identity",
        "name": "caracalai-identity",
        "dir": "packages/identity/python",
        "module": "caracalai_identity",
        "group": "identity",
        "tier": "core",
        "publish": true
      },
      {
        "id": "revocation",
        "name": "caracalai-revocation",
        "dir": "packages/revocation/python",
        "module": "caracalai_revocation",
        "group": "revocation",
        "tier": "core",
        "publish": true
      },
      {
        "id": "sdk",
        "name": "caracalai-sdk",
        "dir": "packages/sdk/python",
        "module": "caracalai",
        "group": "sdk",
        "tier": "sdk",
        "publish": true
      },
      {
        "id": "verify",
        "name": "caracalai-verify",
        "dir": "packages/verify/python",
        "module": "caracalai_verify",
        "group": "verify",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "fastmcp",
        "name": "caracalai-fastmcp",
        "dir": "packages/adapters/fastmcp/python",
        "module": "caracalai_fastmcp",
        "group": "fastmcp",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "asgi",
        "name": "caracalai-asgi",
        "dir": "packages/adapters/asgi/python",
        "module": "caracalai_asgi",
        "group": "asgi",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "redis",
        "name": "caracalai-revocation-redis",
        "dir": "packages/backends/redis/python",
        "module": "caracalai_revocation_redis",
        "group": "revocation-redis",
        "tier": "connector",
        "publish": true
      }
    ],
    "go": [
      {
        "id": "core",
        "module": "github.com/garudex-labs/caracal/packages/core/go",
        "dir": "packages/core/go",
        "group": "core",
        "tier": "core",
        "publish": true
      },
      {
        "id": "oauth",
        "module": "github.com/garudex-labs/caracal/packages/oauth/go",
        "dir": "packages/oauth/go",
        "group": "oauth",
        "tier": "core",
        "publish": true
      },
      {
        "id": "admin",
        "module": "github.com/garudex-labs/caracal/packages/admin/go",
        "dir": "packages/admin/go",
        "group": "admin",
        "tier": "sdk",
        "publish": true
      },
      {
        "id": "identity",
        "module": "github.com/garudex-labs/caracal/packages/identity/go",
        "dir": "packages/identity/go",
        "group": "identity",
        "tier": "core",
        "publish": true
      },
      {
        "id": "revocation",
        "module": "github.com/garudex-labs/caracal/packages/revocation/go",
        "dir": "packages/revocation/go",
        "group": "revocation",
        "tier": "core",
        "publish": true
      },
      {
        "id": "sdk",
        "module": "github.com/garudex-labs/caracal/packages/sdk/go",
        "dir": "packages/sdk/go",
        "group": "sdk",
        "tier": "sdk",
        "publish": true
      },
      {
        "id": "verify",
        "module": "github.com/garudex-labs/caracal/packages/verify/go",
        "dir": "packages/verify/go",
        "group": "verify",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "nethttp",
        "module": "github.com/garudex-labs/caracal/packages/adapters/nethttp/go",
        "dir": "packages/adapters/nethttp/go",
        "group": "nethttp",
        "tier": "connector",
        "publish": true
      },
      {
        "id": "redis",
        "module": "github.com/garudex-labs/caracal/packages/backends/redis/go",
